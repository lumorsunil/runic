({
  echo "1 < 2 = ${1 < 2}"
  echo "1 > 2 = ${1 > 2}"
  echo "4 <= 5.5 = ${4 <= 5.5}"
  echo "5.5 <= 5.5 = ${5.5 <= 5.5}"
  echo "5.6 <= 5.6 = ${5.6 <= 5.5}"
  echo "11 >= 10 = ${11 >= 10}"
  echo "10 >= 10 = ${10 >= 10}"
  echo "9 >= 10 = ${9 >= 10}"
  echo "3 == 3 = ${3 == 3}"
  echo "3.5 == 3.5 = ${3.5 == 3.5}"
  echo "3 == 3.5 = ${3 == 3.5}"
  echo "3 != 3 = ${3 != 3}"
  echo "3.5 != 3.5 = ${3.5 != 3.5}"
  echo "3 != 3.5 = ${3 != 3.5}"
}) | column "-t"
