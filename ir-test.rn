echo "call executable:"
echo "hello from echo"

echo "-e" "\nbasic pipeline:"
echo "hello from echo" | tr "o" "a" | cat

echo "-e" "\nblocks:"
{
  echo "hello from block"
  echo "hello from block again"
}

echo "-e" "\nblock as pipeline stage:"
({
  echo "something"
  echo "something"
  echo "hello"
  echo "something"
  echo "hello"
  cat "server.log"
  echo "something"
}) | grep "hello"

echo "-e" "\nbindings:"
const s = "hello"
echo "${s}, world!"
const p = ", world!"
echo "${s}${p}"
echo "${s}${", world!"}"

echo "-e" "\ncompare:"
echo "(0 = true, 1 = false)"
({
  echo "1 < 2 = ${1 < 2}"
  echo "1 > 2 = ${1 > 2}"
  echo "4 <= 5.5 = ${4 <= 5.5}"
  echo "5.5 <= 5.5 = ${5.5 <= 5.5}"
  echo "5.6 <= 5.6 = ${5.6 <= 5.5}"
  echo "11 >= 10 = ${11 >= 10}"
  echo "10 >= 10 = ${10 >= 10}"
  echo "9 >= 10 = ${9 >= 10}"
  echo "3 == 3 = ${3 == 3}"
  echo "3.5 == 3.5 = ${3.5 == 3.5}"
  echo "3 == 3.5 = ${3 == 3.5}"
  echo "3 != 3 = ${3 != 3}"
  echo "3.5 != 3.5 = ${3.5 != 3.5}"
  echo "3 != 3.5 = ${3 != 3.5}"
}) | column "-t"

echo "-e" "\nlogical:"
echo "(0 = true, 1 = false)"
({
  echo "true && true = ${true && true}"
  echo "false && true = ${false && true}"
  echo "true && false = ${true && false}"
  echo "false && false = ${false && false}"

  echo "true || true = ${true || true}"
  echo "false || true = ${false || true}"
  echo "true || false = ${true || false}"
  echo "false || false = ${false || false}"

  echo "true || true && true = ${true || true && true}"
  echo "true || true && false = ${true || true && false}"
  echo "true || false && true = ${true || false && true}"
  echo "true || false && false = ${true || false && false}"
  echo "false || true && true = ${false || true && true}"
  echo "false || true && false = ${false || true && false}"
  echo "false || false && true = ${false || false && true}"
  echo "false || false && false = ${false || false && false}"
}) | column "-t"

echo "-e" "\nfunctions:"
fn Void hello() Void {
  echo "hello from function"
}
hello

echo "-e" "\nfunction call as pipeline stage:"
hello | tr "o" "a"

echo "-e" "\nif statements:"
echo "is true == true?"
if (true) {
  echo "yes"
} else {
  echo "no"
}
echo "is 5 == 3?"
if (5 == 3) {
  echo "yes"
} else {
  echo "no"
}
