const E = error {
    Bad,
    WithMsg: String,
}

// A bare ok payload value coerces into the E!String stdout type.
fn Void okFn() E!String { yield "ok value" }

// An error value also satisfies the same E!String stdout type.
fn Void errFn() E!String { yield E.Bad }

// The calls return an error union, so they are handled: okFn's ok value passes
// through, errFn's error takes the fallback.
echo "${okFn catch "fb"}"
echo "|"
echo "${errFn catch "fb"}"
echo "|"
