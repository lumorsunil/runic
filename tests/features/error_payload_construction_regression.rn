const E = error {
    Bad,
    WithMsg: String,
}

// Payloaded error value construction, bound and inline.
const e = E{ .WithMsg = "boom" }
echo "bound: ${e}"
echo "inline: ${E{ .WithMsg = "direct" }}"

// Constructed and yielded into an error-union stdout type; handled at the call.
fn Void f() E!String { yield E{ .WithMsg = "yielded" } }
echo "f: ${f catch |err| match err { E.WithMsg => |m| m, _ => "other" }}"
echo "|"
