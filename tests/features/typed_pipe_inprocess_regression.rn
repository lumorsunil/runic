// In-process typed transport: `Int` values pass between pipeline stages without
// a text serialize/re-parse round-trip (the inter-stage pipe is marked `typed`,
// so `yield` stores the value and `&0` reads it back directly). `&0` is a
// consuming read, so the single input is bound once and reused.

fn Int add_one() Int {
    yield &0 + 1
}

echo "6" | parseInt | { const n = &0; yield n * n } | add_one
