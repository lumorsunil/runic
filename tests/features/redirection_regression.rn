const base = "/tmp/runic-redirection-regression"
const path = "${base}.txt"

echo "first" > "${path}"
cat "${path}"

echo "replace" > "${path}"
cat "${path}"

echo "tail" >> "${path}"
cat "${path}"

const file_name = "${base}-ident.txt"

echo "ident-first" > file_name
cat "${file_name}"

echo "ident-tail" >> file_name
cat "${file_name}"
